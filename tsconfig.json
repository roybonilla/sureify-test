{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "paths": {
      "@/*": ["./src/*"],
      "@types": ["./types/index.ts"]
    },

    "types": ["vitest/globals", "node"]
  },
  "include": ["src", "test", "types"]
}